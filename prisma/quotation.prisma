model Quotation {
  id              String           @id @default(uuid())
  quotationNumber String           @unique

  companyType     String?

  companyName     String
  companyAddress  String
  companyPhone    String
  companyEmail    String

  clientName      String
  clientAddress   String?
  clientPhone     String?
  clientEmail     String?

  quotationDate   DateTime
  validTill       DateTime

  discount        Float            @default(0)
  grandTotal      Float

  notes           String?
  customTerms     String[]
  salesPersonName String

  items           QuotationItem[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model QuotationItem {
  id           String     @id @default(uuid())
  quotationId  String

  title        String
  description  String?
  rate         Float

  quotation    Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}